# AI Tutor Backend Configuration
# Copy this file to .env and fill in your values

# Application
# Human-readable name for the service
APP_NAME="AI Tutor API"

# API routing prefix (default: /api/v1)
API_PREFIX="/api/v1"

# Enable debug mode for development (default: false)
DEBUG=false

# Database
# PostgreSQL connection string
DATABASE_URL="postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/ai_tutor"

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600

# Security
# Secret key for JWT signing - use a strong random value in production
SECRET_KEY="change-me-in-production-use-strong-random-key"

# Token expiration settings
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT algorithm for token signing
ALGORITHM="HS256"

# CORS
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# OpenAI API Key
# Required for LLM-generated hints (L3/L4)
OPENAI_API_KEY=""

# Code Execution - Judge0
# API key for Judge0 RapidAPI proxy (optional if self-hosting)
JUDGE0_API_KEY=""
JUDGE0_BASE_URL="https://judge0-ce.p.rapidapi.com"

# Rate Limiting
# Maximum submissions per minute per user
RATE_LIMIT_PER_MINUTE=60
# Maximum LLM hint requests per minute per user
RATE_LIMIT_LLM_PER_MINUTE=10

# Redis / Caching
# Redis connection URL for session and hint caching
REDIS_URL="redis://localhost:6379/0"
# Default cache TTL in seconds
CACHE_TTL_SECONDS=300
